<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chipping Request Intake Guide</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1a2e;
    --paper: #faf9f6;
    --accent: #b45309;
    --accent-light: #fef3c7;
    --accent-mid: #f59e0b;
    --teal: #0d9488;
    --teal-light: #ccfbf1;
    --blue: #3a6ea5;
    --blue-light: #dbeafe;
    --green: #2d6a4f;
    --green-light: #d8f3dc;
    --grey: #6b7280;
    --grey-light: #f3f4f6;
    --warm-dark: #c9a96e;
    --border: #e5e7eb;
    --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.07);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.65;
    font-size: 15px;
  }

  /* ── Header ── */
  header {
    background: var(--ink);
    color: white;
    padding: 48px 40px 40px;
    position: relative;
    overflow: hidden;
  }
  header::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--accent), var(--accent-mid), var(--teal));
  }
  header h1 {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
  }
  header p {
    opacity: 0.7;
    font-size: 14px;
    max-width: 600px;
  }

  /* ── Layout ── */
  .layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    max-width: 1200px;
    margin: 0 auto;
    min-height: calc(100vh - 140px);
  }

  /* ── Sidebar ── */
  nav {
    border-right: 1px solid var(--border);
    padding: 24px 0;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    background: white;
    font-size: 13px;
  }
  nav .nav-group {
    padding: 0 16px;
    margin-bottom: 20px;
  }
  nav .nav-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--grey);
    margin-bottom: 8px;
    padding-left: 4px;
  }
  nav a {
    display: block;
    padding: 5px 10px;
    color: var(--ink);
    text-decoration: none;
    border-radius: 5px;
    transition: background 0.15s;
    line-height: 1.4;
  }
  nav a:hover { background: var(--grey-light); }
  nav a.path-a { border-left: 3px solid var(--accent); padding-left: 7px; }
  nav a.path-b { border-left: 3px solid var(--teal); padding-left: 7px; }

  /* ── Main ── */
  main {
    padding: 36px 48px 80px;
    max-width: 820px;
  }

  /* ── Purpose Box ── */
  .purpose-box {
    background: white;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px 28px;
    margin-bottom: 36px;
    box-shadow: var(--shadow);
  }
  .purpose-box h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.15rem;
    margin-bottom: 10px;
    color: var(--ink);
  }
  .purpose-box p { color: var(--grey); font-size: 14px; }

  /* ── Systems Chips ── */
  .systems {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
    background: var(--grey-light);
    color: var(--ink);
    border: 1px solid var(--border);
  }
  .chip .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent-mid);
  }

  /* ── Decision Fork ── */
  .fork {
    background: white;
    border-radius: 10px;
    border: 1px solid var(--border);
    padding: 28px;
    margin: 32px 0;
    box-shadow: var(--shadow);
  }
  .fork h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.1rem;
    margin-bottom: 16px;
    text-align: center;
  }
  .fork-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .fork-card {
    border-radius: 8px;
    padding: 18px 20px;
    text-align: center;
    cursor: default;
  }
  .fork-card.a {
    background: var(--accent-light);
    border: 2px solid var(--accent);
  }
  .fork-card.b {
    background: var(--teal-light);
    border: 2px solid var(--teal);
  }
  .fork-card .icon { font-size: 24px; margin-bottom: 6px; }
  .fork-card strong { display: block; font-size: 14px; margin-bottom: 2px; }
  .fork-card span { font-size: 12px; color: var(--grey); }

  /* ── Section Headers ── */
  .section-header {
    margin: 44px 0 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--border);
  }
  .section-header.a { border-bottom-color: var(--accent); }
  .section-header.b { border-bottom-color: var(--teal); }
  .section-header h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.35rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-header .badge {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .section-header.a .badge { background: var(--accent-light); color: var(--accent); }
  .section-header.b .badge { background: var(--teal-light); color: var(--teal); }

  /* ── Step Cards ── */
  .step {
    background: white;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 22px 24px;
    margin-bottom: 16px;
    box-shadow: var(--shadow);
    position: relative;
  }
  .step-num {
    position: absolute;
    top: -10px;
    left: 20px;
    font-size: 11px;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 4px;
    letter-spacing: 0.04em;
  }
  .step.a .step-num { background: var(--accent); color: white; }
  .step.b .step-num { background: var(--teal); color: white; }

  .step h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 10px;
    padding-top: 4px;
  }
  .step p { margin-bottom: 8px; color: #374151; font-size: 14px; }
  .step ul, .step ol {
    padding-left: 20px;
    margin: 8px 0;
    color: #374151;
    font-size: 14px;
  }
  .step li { margin-bottom: 4px; }
  .step li li { margin-bottom: 2px; }

  /* ── Callout Boxes ── */
  .callout {
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 13px;
    margin: 10px 0;
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .callout.tip { background: var(--accent-light); color: #78350f; }
  .callout.warn { background: #fff7ed; color: #9a3412; border: 1px solid #fed7aa; }
  .callout.info { background: var(--blue-light); color: #1e40af; }
  .callout.green { background: var(--green-light); color: #1b4332; }
  .callout.teal { background: var(--teal-light); color: #134e4a; }
  .callout .callout-icon { flex-shrink: 0; font-size: 15px; margin-top: 1px; }

  /* ── Decision Box ── */
  .decision-box {
    border: 1px solid var(--border);
    border-radius: 8px;
    margin: 12px 0;
    overflow: hidden;
  }
  .decision-header {
    background: var(--grey-light);
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    border-bottom: 1px solid var(--border);
  }
  .decision-row {
    display: grid;
    grid-template-columns: auto 1fr;
    border-bottom: 1px solid var(--border);
  }
  .decision-row:last-child { border-bottom: none; }
  .decision-label {
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 120px;
  }
  .decision-label.yes { color: var(--green); background: var(--green-light); }
  .decision-label.no { color: var(--accent); background: var(--accent-light); }
  .decision-content {
    padding: 10px 14px;
    font-size: 13px;
    color: #374151;
    line-height: 1.55;
  }

  /* ── Required Info Grid ── */
  .required-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin: 10px 0;
  }
  .req-item {
    background: #f8fafc;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 13px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .req-item .req-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  /* ── Conditional Block ── */
  .conditional {
    border-left: 3px solid var(--warm-dark);
    padding-left: 16px;
    margin: 12px 0;
  }
  .conditional-label {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--warm-dark);
    margin-bottom: 6px;
  }

  /* ── Inline Link ── */
  .inline-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    word-break: break-all;
  }

  /* ── Time Tracking Badge ── */
  .time-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--blue-light);
    color: #1e40af;
    font-size: 12px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  /* ── Bloomerang Field List ── */
  .field-list {
    margin: 10px 0;
  }
  .field-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 5px 0;
    font-size: 13px;
    border-bottom: 1px solid #f3f4f6;
  }
  .field-row:last-child { border-bottom: none; }
  .field-label {
    font-weight: 600;
    min-width: 140px;
    color: var(--ink);
  }
  .field-value {
    color: var(--grey);
  }

  /* ── Checklist ── */
  .checklist-section {
    background: white;
    border: 2px solid var(--ink);
    border-radius: 10px;
    padding: 28px;
    margin-top: 44px;
    box-shadow: var(--shadow-md);
  }
  .checklist-section h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.2rem;
    margin-bottom: 18px;
    text-align: center;
  }
  .check-group {
    margin-bottom: 14px;
  }
  .check-group-title {
    font-weight: 600;
    font-size: 13px;
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .check-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
    font-size: 13.5px;
    color: #374151;
  }
  .check-item input[type="checkbox"] {
    accent-color: var(--accent);
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* ── Cross-reference tag ── */
  .xref {
    display: inline-block;
    background: var(--grey-light);
    border: 1px solid var(--border);
    padding: 1px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    color: var(--grey);
  }

  /* ── Responsive ── */
  @media (max-width: 800px) {
    .layout { grid-template-columns: 1fr; }
    nav { display: none; }
    main { padding: 24px 20px 60px; }
    header { padding: 32px 20px; }
    .fork-cards { grid-template-columns: 1fr; }
    .required-grid { grid-template-columns: 1fr; }
    .decision-row { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<header>
  <h1>Chipping Request Intake Guide</h1>
  <p>Standard operating procedure for receiving and processing chipping requests, whether submitted online or delivered as physical forms.</p>
</header>

<div class="layout">

<!-- ── Sidebar ── -->
<nav>
  <div class="nav-group">
    <div class="nav-label">Overview</div>
    <a href="#purpose">Purpose &amp; Systems</a>
    <a href="#start">Identify Submission Type</a>
  </div>
  <div class="nav-group">
    <div class="nav-label">Path A &mdash; Online Form</div>
    <a class="path-a" href="#a1">Open Email Alert</a>
    <a class="path-a" href="#a2">Review Notes &amp; Address</a>
    <a class="path-a" href="#a3">Set Chipping Status</a>
    <a class="path-a" href="#a4">Verify Required Info</a>
    <a class="path-a" href="#a5">Contractor &amp; Grant</a>
    <a class="path-a" href="#a6">Save</a>
  </div>
  <div class="nav-group">
    <div class="nav-label">Path B &mdash; Physical Form</div>
    <a class="path-b" href="#b1">Create / Find Profile</a>
    <a class="path-b" href="#b2">Create Interaction</a>
    <a class="path-b" href="#b3">Fill In &amp; Verify</a>
    <a class="path-b" href="#b4">Save &amp; File</a>
  </div>
  <div class="nav-group">
    <div class="nav-label">Wrap Up</div>
    <a href="#checklist">Completion Checklist</a>
  </div>
</nav>

<!-- ── Main Content ── -->
<main>

  <!-- Purpose -->
  <div class="purpose-box" id="purpose">
    <h2>Purpose</h2>
    <p>Ensure all chipping requests are accurately received, reviewed, assigned a status, and recorded in Bloomerang so that scheduling and outreach can proceed smoothly.</p>
    <div class="systems">
      <span class="chip"><span class="dot"></span>Bloomerang (CRM)</span>
      <span class="chip"><span class="dot"></span>Asana (Chipping 2026)</span>
      <span class="chip"><span class="dot"></span>chipping@theclerc.org</span>
      <span class="chip"><span class="dot"></span>Lake County Parcel Viewer</span>
    </div>
  </div>

  <!-- Decision Fork -->
  <div class="fork" id="start">
    <h2>How Was the Request Submitted?</h2>
    <div class="fork-cards">
      <div class="fork-card a">
        <div class="icon">&#128187;</div>
        <strong>Online Form</strong>
        <span>Follow Path A below</span>
      </div>
      <div class="fork-card b">
        <div class="icon">&#9993;</div>
        <strong>Mailed / Dropped Off</strong>
        <span>Skip to Path B below</span>
      </div>
    </div>
  </div>


  <!-- ═══════════════ PATH A ═══════════════ -->
  <div class="section-header a" id="path-a">
    <h2><span class="badge">Path A</span> Online Form Submissions</h2>
  </div>

  <!-- A1 -->
  <div class="step a" id="a1">
    <div class="step-num">A1</div>
    <h3>Open the Email Alert</h3>
    <span class="time-badge">&#9202; Switch time tracking to CWDG-1</span>
    <ol>
      <li>When a property owner submits the online sign-up form, a Bloomerang notification is sent to <strong>chipping@theclerc.org</strong>.</li>
      <li>Open the email alert and click <strong>"View this interaction in Bloomerang"</strong>.</li>
    </ol>
    <div class="callout warn">
      <span class="callout-icon">&#9888;</span>
      <div><strong>Watch for nested emails:</strong> If multiple chipping requests were submitted close together, Gmail may group them into a single thread. Expand each message in the chain and verify they aren't different property owners or addresses before proceeding.</div>
    </div>
  </div>

  <!-- A2 -->
  <div class="step a" id="a2">
    <div class="step-num">A2</div>
    <h3>Review Notes &amp; Address</h3>
    <ol>
      <li>Read any notes left by the property owner at the top of the interaction. Determine if any follow-up is needed.</li>
      <li>Scroll down to <strong>"Street Address To Be Chipped"</strong> and confirm it is filled in.</li>
      <li>Note where the property is located and whether it falls within an <strong>HOA area</strong>.</li>
    </ol>
    <div class="callout tip">
      <span class="callout-icon">&#128161;</span>
      <div><strong>How to check for HOA:</strong> The form includes a dropdown listing common HOAs. If the property owner didn't select one, check the address on a map to see if it's in the general area of a known HOA community.</div>
    </div>
  </div>

  <!-- A3 -->
  <div class="step a" id="a3">
    <div class="step-num">A3</div>
    <h3>Set Chipping Status</h3>
    <p>Scroll up to <strong>"Chipping Status For This Event"</strong> and set it based on whether a pre-scheduled event exists in the property's area.</p>
    <p style="font-size:13px; color:var(--grey); margin-bottom:8px;">Check the <strong>"Chipping 2026"</strong> Asana project, or look at the Bloomerang dropdown <em>"Chipping Event You'd Like To Sign Up For"</em> (which lets property owners select a pre-scheduled event if one exists in their area).</p>

    <div class="decision-box">
      <div class="decision-header">Is there a pre-scheduled event in the property's area?</div>
      <div class="decision-row">
        <div class="decision-label yes">&#10004; YES</div>
        <div class="decision-content">
          Set status to <strong>"Scheduled"</strong>.<br>
          Set <strong>"Date Chipping Is Scheduled For"</strong> to the <strong>first day</strong> of that event.<br>
          <em style="color:var(--grey);">Example: If the event runs May 8–10, enter 05/08/2026.</em><br>
          If the property owner didn't select an event in the dropdown but is located within the area of an upcoming one, select the event for them.
        </div>
      </div>
      <div class="decision-row">
        <div class="decision-label no">&#10008; NO</div>
        <div class="decision-content">
          Set status to <strong>"Requested"</strong>.<br>
          This means they fall outside a pre-scheduled event. They'll be added as a singular event later, or grouped once more sign-ups occur in the area.
        </div>
      </div>
    </div>
  </div>

  <!-- A4 -->
  <div class="step a" id="a4">
    <div class="step-num">A4</div>
    <h3>Verify Required Information</h3>
    <p>Scroll through the form and confirm all required fields are filled in. The more detail the better, but at minimum you need:</p>

    <div class="required-grid">
      <div class="req-item"><span class="req-dot"></span> "I have read the ROE" (confirmed)</div>
      <div class="req-item"><span class="req-dot"></span> Address to be chipped</div>
      <div class="req-item"><span class="req-dot"></span> City to be chipped</div>
      <div class="req-item"><span class="req-dot"></span> Size of the property</div>
      <div class="req-item"><span class="req-dot"></span> Do you want the chips, and how?</div>
    </div>

    <div class="conditional">
      <div class="conditional-label">If required info is missing</div>
      <ol>
        <li>Fill in what you can using the <strong>Lake County Parcel Viewer</strong> to look up acreage and city by address:<br>
          <a class="inline-link" href="https://gis.lakecountyca.gov/portal/apps/experiencebuilder/experience/?id=125d35323cdd4acfa546691978fe9155" target="_blank" style="font-size:12px;">gis.lakecountyca.gov &rarr; Parcel Viewer</a>
        </li>
        <li>If critical information still can't be found, reach out to the property owner directly to confirm, then fill it in.</li>
      </ol>
    </div>
  </div>

  <!-- A5 -->
  <div class="step a" id="a5">
    <div class="step-num">A5</div>
    <h3>Contractor &amp; Grant Info</h3>
    <p>If the contractor for the property owner's event is already known:</p>
    <ol>
      <li>Scroll to the bottom of the interaction.</li>
      <li>Fill in the <strong>contractor code</strong>.</li>
      <li>Set the grant to <strong>CWDG-1</strong>.</li>
    </ol>
    <div class="callout info">
      <span class="callout-icon">&#128161;</span>
      <div>If no contractor is assigned yet, leave these fields blank for now. They'll be filled in once scheduling is finalized.</div>
    </div>
  </div>

  <!-- A6 -->
  <div class="step a" id="a6">
    <div class="step-num">A6</div>
    <h3>Save the Interaction</h3>
    <p>Scroll up and click <strong>Save</strong>. The online intake is complete.</p>
  </div>


  <!-- ═══════════════ PATH B ═══════════════ -->
  <div class="section-header b" id="path-b">
    <h2><span class="badge">Path B</span> Physical Form (Mailed / Dropped Off)</h2>
  </div>

  <!-- B1 -->
  <div class="step b" id="b1">
    <div class="step-num">B1</div>
    <h3>Create or Find the Bloomerang Profile</h3>
    <span class="time-badge">&#9202; Switch time tracking to CWDG-1</span>
    <ol>
      <li>Search for the property owner in Bloomerang.</li>
    </ol>
    <div class="conditional">
      <div class="conditional-label">If no profile exists</div>
      <p>Create a new profile. Include their name, address, and any contact information provided on the form.</p>
    </div>
  </div>

  <!-- B2 -->
  <div class="step b" id="b2">
    <div class="step-num">B2</div>
    <h3>Create a New Interaction</h3>
    <p>On the property owner's profile, create an interaction with the following settings:</p>

    <div class="field-list">
      <div class="field-row">
        <span class="field-label">Subject</span>
        <span class="field-value">Chipping Requests</span>
      </div>
      <div class="field-row">
        <span class="field-label">Purpose</span>
        <span class="field-value">Special Event</span>
      </div>
      <div class="field-row">
        <span class="field-label">Channel</span>
        <span class="field-value">Mail</span>
      </div>
      <div class="field-row">
        <span class="field-label">Initiated by</span>
        <span class="field-value">Constituent &nbsp;(checked)</span>
      </div>
    </div>
  </div>

  <!-- B3 -->
  <div class="step b" id="b3">
    <div class="step-num">B3</div>
    <h3>Fill In Details &amp; Verify</h3>
    <ol>
      <li>Enter all details from the physical form into the interaction.</li>
      <li>Follow the same review and verification steps as the online path:</li>
    </ol>
    <ul style="margin-top:6px;">
      <li>Review notes and address <span class="xref">Same as A2</span></li>
      <li>Set chipping status (Scheduled or Requested) <span class="xref">Same as A3</span></li>
      <li>Verify all required info is present <span class="xref">Same as A4</span></li>
      <li>Add contractor code and grant if known <span class="xref">Same as A5</span></li>
    </ul>
  </div>

  <!-- B4 -->
  <div class="step b" id="b4">
    <div class="step-num">B4</div>
    <h3>Save &amp; File the Physical Form</h3>
    <ol>
      <li>Save the interaction in Bloomerang.</li>
      <li>File the physical form in the filing cabinet.</li>
    </ol>
  </div>


  <!-- ═══════════════ CHECKLIST ═══════════════ -->
  <div class="checklist-section" id="checklist">
    <h2>&#9989; Completion Checklist</h2>
    <p style="text-align:center; font-size:13px; color:var(--grey); margin-bottom:18px;">Confirm all items before moving on to the next request.</p>

    <div class="check-group">
      <div class="check-group-title">&#9202; Time Tracking</div>
      <label class="check-item"><input type="checkbox"> Time tracked to CWDG-1</label>
    </div>

    <div class="check-group">
      <div class="check-group-title">&#128218; Bloomerang Interaction</div>
      <label class="check-item"><input type="checkbox"> Interaction opened (or created for physical forms)</label>
      <label class="check-item"><input type="checkbox"> Property owner notes reviewed</label>
      <label class="check-item"><input type="checkbox"> Street address confirmed</label>
      <label class="check-item"><input type="checkbox"> HOA status checked</label>
    </div>

    <div class="check-group">
      <div class="check-group-title">&#128197; Chipping Status</div>
      <label class="check-item"><input type="checkbox"> Status set to "Scheduled" or "Requested"</label>
      <label class="check-item"><input type="checkbox"> If scheduled: date set to first day of event</label>
      <label class="check-item"><input type="checkbox"> If scheduled: correct event selected in dropdown</label>
    </div>

    <div class="check-group">
      <div class="check-group-title">&#128203; Required Information</div>
      <label class="check-item"><input type="checkbox"> ROE acknowledgment confirmed</label>
      <label class="check-item"><input type="checkbox"> Address, city, property size filled in</label>
      <label class="check-item"><input type="checkbox"> Chip preference noted</label>
      <label class="check-item"><input type="checkbox"> Missing info filled via Parcel Viewer or property owner contact</label>
    </div>

    <div class="check-group">
      <div class="check-group-title">&#128194; Wrap Up</div>
      <label class="check-item"><input type="checkbox"> Contractor code and grant filled (if known)</label>
      <label class="check-item"><input type="checkbox"> Interaction saved</label>
      <label class="check-item"><input type="checkbox"> Physical form filed (if applicable)</label>
    </div>
  </div>

</main>
</div>

</body>
</html>
